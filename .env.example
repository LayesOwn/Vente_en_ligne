# ── Environnement ─────────────────────────────────────────────────────────────
# "production" active : HSTS, CORS strict, docs désactivées, vérifications renforcées
ENVIRONMENT=development

# ── Sécurité ──────────────────────────────────────────────────────────────────
# Clé secrète JWT — OBLIGATOIRE en production, min 32 caractères
# Générer : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=remplacer_par_une_cle_secrete_aleatoire_de_32_caracteres_minimum

# Mot de passe de l'interface admin
ADMIN_PASSWORD=remplacer_par_un_mot_de_passe_fort

# ── Base de données ────────────────────────────────────────────────────────────
# SQLite (développement local)
DATABASE_URL=sqlite:///./dasha_shop.db
# PostgreSQL (production recommandé)
# DATABASE_URL=postgresql://user:password@host/dbname

# ── Fichiers uploadés ──────────────────────────────────────────────────────────
UPLOAD_DIR=uploads

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL exacte du frontend (sans slash final)
# Dev : http://localhost:5173
# Prod : https://votrecompte.pythonanywhere.com
FRONTEND_URL=http://localhost:5173

# ── Notifications Telegram (optionnel) ────────────────────────────────────────
# Créer un bot via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
